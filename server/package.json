{
  "name": "job-board-server",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "concurrently \"nodemon src/server.ts\" \"graphql-codegen --config codegen.json --watch\"",
    "start:safe": "./safe-start.sh",
    "start:prod": "node dist/server.js",
    "codegen": "graphql-codegen --config codegen.json",
    "db:health": "tsx -e \"import('./src/db/health.js').then(m => m.DatabaseHealth.checkHealth().then(h => console.log(JSON.stringify(h, null, 2))))\"",
    "db:maintenance": "tsx -e \"import('./src/db/health.js').then(m => m.DatabaseHealth.performMaintenance())\"",
    "db:stats": "tsx -e \"import('./src/db/health.js').then(m => m.DatabaseHealth.getStats().then(s => console.log(JSON.stringify(s, null, 2))))\""
  },
  "dependencies": {
    "@apollo/server": "^4.9.4",
    "better-auth": "^1.5.5",
    "better-sqlite3": "12.8.0",
    "cors": "^2.8.5",
    "dataloader": "^2.2.2",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-jwt": "^8.4.1",
    "form-data": "^4.0.1",
    "graphql": "^16.8.1",
    "jsonwebtoken": "^9.0.0",
    "kysely": "^0.28.8",
    "mailgun.js": "^12.7.1",
    "nanoid": "^5.0.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typescript": "^4.0.1",
    "@graphql-codegen/typescript-resolvers": "^4.0.1",
    "@parcel/watcher": "^2.3.0",
    "@tsconfig/node18": "^18.2.2",
    "@types/cors": "^2.8.14",
    "concurrently": "^9.1.2",
    "nodemon": "^3.0.1",
    "tsx": "^4.6.2",
    "typescript": "^5.2.2"
  },
  "nodemonConfig": {
    "ext": "graphql,ts",
    "execMap": {
      "ts": "tsx"
    }
  }
}
