# Copy this file to .env and fill in your real values
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:9000
MAILGUN_SECRET_KEY=your-mailgun-api-key-here
STRIPE_SECRET_KEY=your-stripe-secret-key-here

# Comma-separated origins allowed by CORS and Better Auth
CORS_ORIGINS=http://localhost:4321,http://localhost:3000
TRUSTED_ORIGINS=http://localhost:4321,http://localhost:3000

# Defaults shown below are suitable for local dev; in Docker this is set to /app/data/db.sqlite3
AUTH_DB_PATH=./data/db.sqlite3
CLIENT_ORIGIN=http://localhost:4321