---
import "../assets/main.css";
import HeaderWithMenu from "../components/_layout/HeaderWithMenu.astro";
import HeroHeader from "../components/_layout/HeroHeader.astro";
import Footer from "../components/_layout/Footer.astro";
import { ClientRouter } from "astro:transitions";
import LoadingIndicator from "astro-loading-indicator/component";

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title ? `${title} - Tennis Court Reservation` : "Tennis Court Reservation"}</title>
		<ClientRouter />
		<LoadingIndicator color="#ca340b" />
	</head>
	<body>
		<div class="flex flex-col min-h-screen">
			<HeaderWithMenu client:load transition:persist />
			<HeroHeader title={title || 'The world healthiest sport'} />
			<div class="main-content mt-8 pb-8">
				<slot />
			</div>
			<Footer />
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	.main-content {
		flex-grow: 1;
	}
</style>
