---
import { SubscriptionBox } from '../components/subscription-box/SubscriptionBox';

import type { GraphQLBooking } from '../lib/graphql/.generatedTypes';
import { getBookings } from '../lib/graphql';
import AccountPageLayout from './_layout/AccountPageLayout.astro';

interface Props {
  user: any;
  session: any;
}

const { user } = Astro.props;

// Check if subscription was successful from query parameter
const subscriptionSuccess = Astro.url.searchParams.get('subscription') === 'success';

const bookings: GraphQLBooking[] = await getBookings(user?.id);
const now = new Date();

const bookingsToCome = bookings.filter((booking) => {
	if (!booking.date || !booking.hour) return false;

	const bookingDate = new Date(booking.date);
	const bookingHour = parseInt(booking.hour);
	
	const bookingDateTime = new Date(bookingDate);
	bookingDateTime.setHours(bookingHour, 0, 0, 0);
	
	return bookingDateTime > now;
}).sort((a, b) => {
	const dateA = new Date(a.date || '');
	const dateB = new Date(b.date || '');
	const hourA = parseInt(a.hour || '0');
	const hourB = parseInt(b.hour || '0');
	
	if (dateA.toDateString() === dateB.toDateString()) {
		return hourA - hourB;
	}
	
	return dateA.getTime() - dateB.getTime();
});
---
<AccountPageLayout>
	<div class="flex gap-6 flex-wrap">
		<div class="card w-96 bg-base-200 card-lg shadow-sm">
			<div class="card-body">
				<h2 class="card-title">Account information</h2>
				<ul class="list-inside mt-2">
					<li class="mb-1"><strong>Name:</strong> {user.name} {user.surname}</li>
					<li class="mb-1"><strong>Email:</strong> {user.email}</li>
					<li class="mb-1"><strong>Member since:</strong> {new Date(user.createdAt).toLocaleDateString()}</li>
				</ul>
			</div>
		</div>

		<div class="card w-96 bg-base-200 card-lg shadow-sm">
			<div class="card-body">
				<h2 class="card-title">Bookings</h2>
				{bookingsToCome.length === 0 ? (
					<p>You have no upcoming bookings.</p>
				) : (
					<ul class="booking-list">
						{bookingsToCome.map((booking, key) => (
							<li class="booking-list-item">
								<div class="booking-preview">
									<span class="month">{new Date(booking?.date || '').toLocaleDateString('en-US', { month: 'short' })}</span>
									<span class="date">{new Date(booking?.date || '').getDate()}</span>
								</div>
								<div class="booking-item">
									<div class="booking-item-header">
										<span class="booking-item-court">{booking.courtName}</span>&nbsp;at&nbsp;
										<span class="booking-item-date">
											{booking.hour}:00
										</span>
									</div>
									<div class="booking-item-players"><strong>{booking.player1}</strong> vs <strong>{booking.player2}</strong></div>
								</div>
							</li>
						))}
					</ul>
				)}
			</div>
		</div>
		<SubscriptionBox 
			userEmail={user?.email} 
			isAuthenticated={true}
			client:load
		/>
	</div>
</AccountPageLayout>
<style>
	.booking-list {
		display: flex;
		flex-direction: column;
	}

	.booking-list-item {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 10px 0;
		margin: 0;
		border-bottom: 1px solid var(--c-light-grey);

		&:last-child {
			border-bottom: none;
		}
	}

	.booking-item {
		display: flex;
		flex-direction: column;
	}

	.booking-item-header {
		display: flex;
		font-size: 16px;
	}

	.booking-item-players {
		font-size: 14px;
		color: var(--c-dark-grey);
	}

	.booking-preview {
		background: white;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 5px 10px;
		border-radius: 5px;
		min-width: 50px;

		.month {
			font-size: 14px;
			color: var(--c-main-accent);
		}

		.date {
			font-size: 18px;
			font-weight: bold;
		}
	}
</style>