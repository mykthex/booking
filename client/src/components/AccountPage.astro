---
import SimpleColumn from '../components/SimpleColumn.astro';
import { SubscriptionBox } from '../components/subscription-box/SubscriptionBox';

import type { GraphQLBooking, GraphQLCourt, GraphQLUser } from '../lib/graphql/.generatedTypes';
import { getBookings, getCourts, getPlayers } from '../lib/graphql';
import { auth } from '../../../server/auth';
import AccountMenu from './AccountMenu.astro';

// Get user session from better-auth
const session = await auth.api.getSession({
  headers: Astro.request.headers
});

const user = session?.user;
const isAuthenticated = !!user;

const bookings: GraphQLBooking[] = await getBookings(user?.id);
const now = new Date();

const bookingsToCome = bookings.filter((booking) => {
	console.log('Booking date:', booking.date, 'Booking hour:', booking.hour);
	if (!booking.date || !booking.hour) return false;

	const bookingDate = new Date(booking.date);
	const bookingHour = parseInt(booking.hour);
	
	const bookingDateTime = new Date(bookingDate);
	bookingDateTime.setHours(bookingHour, 0, 0, 0);
	
	return bookingDateTime > now;
}).sort((a, b) => {
	const dateA = new Date(a.date || '');
	const dateB = new Date(b.date || '');
	const hourA = parseInt(a.hour || '0');
	const hourB = parseInt(b.hour || '0');
	
	if (dateA.toDateString() === dateB.toDateString()) {
		return hourA - hourB;
	}
	
	return dateA.getTime() - dateB.getTime();
});
---
<div class="main-container">
	<SimpleColumn>
		<div class="account-page">
			<AccountMenu />

			<div class="content">
				{!isAuthenticated ? (
					<div class="mb-4 p-4 bg-warning/20 rounded-box">
						<p class="text-warning-content">Please log in to view your account details.</p>
					</div>
				) : (
					<h2 class="text-lg font-semibold">
						Hello, <span class="text-primary">{user.name} {user.surname} ({user.email})</span>!
					</h2>
					<div class="flex gap-6 flex-wrap">
						<div class="card w-96 bg-base-200 card-lg shadow-sm mt-6">
							<div class="card-body">
								<h2 class="card-title">Account information</h2>
								<ul class="list-inside mt-2">
									<li class="mb-1"><strong>Name:</strong> {user.name} {user.surname}</li>
									<li class="mb-1"><strong>Email:</strong> {user.email}</li>
									<li class="mb-1"><strong>Member since:</strong> {new Date(user.createdAt).toLocaleDateString()}</li>
								</ul>
							</div>
						</div>

						<div class="card w-96 bg-base-200 card-lg shadow-sm mt-6">
							<div class="card-body">
								<h2 class="card-title">Bookings</h2>
								{bookingsToCome.length === 0 ? (
									<p>You have no upcoming bookings.</p>
								) : (
									<ul class="list bg-base-100 rounded-box shadow-md">
										{bookingsToCome.map((booking, key) => (
											<li class="list-row">
												<div class="text-4xl font-thin opacity-30 tabular-nums">{key + 1}</div>
												<div class="list-col-grow">
													<div>
														{new Date(booking?.date || '').toLocaleDateString()} at {booking.hour}:00
													</div>
													<div class="text-xs uppercase font-semibold opacity-60">{booking.courtName}</div>
												</div>
											</li>
										))}
									</ul>
								)}
							</div>
						</div>
						<SubscriptionBox 
							userEmail={user?.email} 
							isAuthenticated={isAuthenticated}
							client:load
						/>
					</div>
				)}
			</div>
		</div>
	</SimpleColumn>
</div>

<style>
	.container {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 40px 20px;
	}

	.account-page {
		display: flex;
		align-items: flex-start;
		gap: 40px;
	}

	h1 {
		font-size: 2.5rem;
		text-align: left;
		margin-bottom: 20px;
	}
</style>
