---
import type { GraphQLBooking, GraphQLCourt, GraphQLUser } from '../lib/graphql/.generatedTypes';
import { CourtReserveAdmin } from './court-reserve-admin/CourtReserveAdmin';
import { getBookings, getCourts, getPlayers } from '../lib/graphql';
import { auth } from '../../../server/auth';
import AccountPageLayout from './AccountPageLayout.astro';

// Get user session from better-auth
const session = await auth.api.getSession({
  headers: Astro.request.headers
});

const user = session?.user;
const isAuthenticated = !!user;

const bookings: GraphQLBooking[] = await getBookings();
const courts: GraphQLCourt[] = await getCourts();
const players: GraphQLUser[] = await getPlayers();
---

<AccountPageLayout>
	{isAuthenticated && <CourtReserveAdmin bookings={bookings} courts={courts} players={players} userId={user?.id} client:load />}
</AccountPageLayout>
