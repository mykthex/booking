---
import SimpleColumn from "./SimpleColumn.astro";

const { title } = Astro.props;
---
<div class="hero">
  {title && (
    <SimpleColumn>
      <div class="flex flex-col justify-end h-full pb-4">
        <h1 class="hero-title">{title}</h1>
      </div>
    </SimpleColumn>
  )}
</div>
<style>
  .hero {
    background: url("/img/intro.jpg") center no-repeat;
    background-size: cover;
    height: calc(300px);
    width: 100%;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;

    &:before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(22, 22, 22, 0.4);
    }

    @media (max-width: 768px) {
      height: calc(40dvh - 60px);
    }
  }

  .hero-title {
    color: white;
    font-size: 3rem;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
    margin: 0;

    @media (max-width: 768px) {
      font-size: 2rem;
    }
  }
</style>