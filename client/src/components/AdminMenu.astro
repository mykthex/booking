---
const currentPath = Astro.url.pathname;
import { auth } from '../../../server/auth';

// Get user session from better-auth
const session = await auth.api.getSession({
  headers: Astro.request.headers
});

const user = session?.user;

// Throw 404 if user is not authenticated
if (user?.role !== 'admin') {
  return new Response(null, { status: 404 });
}
---
<h2 class="mb-2 mt-4">Admin menu</h2>
<ul class="menu menu-lg bg-base-200">
  <li><a href="/admin/booking" class={currentPath === "/admin/booking" ? "menu-active" : ""}>Court management</a></li>
  <li><a href="/admin/users" class={currentPath === "/admin/users" ? "menu-active" : ""}>User management</a></li>
</ul>