---
import type { GraphQLUser } from '../lib/graphql/.generatedTypes';
import { getUsers, getMemberships, getRoles } from '../lib/graphql';
import { getSession } from '../lib/auth-utils';
import { UsersTable } from './users-table/UsersTable';
import AccountPageLayout from './_layout/AccountPageLayout.astro';

// Get user session from Express auth server
const session = await getSession(Astro.request);

const user = session?.user;
const isAuthenticated = !!user;

const players: GraphQLUser[] = await getUsers();
const memberships = await getMemberships();
const roles = await getRoles();
---
<AccountPageLayout>
	{isAuthenticated && <UsersTable users={players} memberships={memberships} roles={roles} client:load />}
</AccountPageLayout>