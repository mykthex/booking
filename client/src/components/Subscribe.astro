---
import { SubscribeForm } from '../components/subscribe-form/Subscribe';
import { SubscriptionBox } from '../components/subscription-box/SubscriptionBox';

import { auth } from '../../../server/auth';
import AccountPageLayout from './AccountPageLayout.astro';

// Get user session from better-auth
const session = await auth.api.getSession({
  headers: Astro.request.headers
});

const user = session?.user;
const isAuthenticated = !!user;

// Check if user has an active subscription
let hasActiveSubscription = false;
if (isAuthenticated && user?.email) {
  try {
    const subscriptionResponse = await fetch("http://localhost:9000/get-user-subscription", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ customer_email: user.email }),
    });
    
    if (subscriptionResponse.ok) {
      const subscriptionData = await subscriptionResponse.json();
      hasActiveSubscription = subscriptionData.subscription && 
        subscriptionData.subscription.status !== 'cancelled' &&
        subscriptionData.subscription.status !== 'incomplete' &&
        !subscriptionData.subscription.is_refunded;
    }
  } catch (error) {
    console.error("Error checking subscription status:", error);
  }
}
---
<AccountPageLayout>
	{isAuthenticated && user ? (
		<div class="profile-section">
			{hasActiveSubscription ? (
				<SubscriptionBox 
					userEmail={user.email || ""}
					isAuthenticated={isAuthenticated}
					client:load
				/>
			) : (
				<SubscribeForm 
					email={user.email || ""}
					client:load
				/>
			)}
		</div>
	) : (
		<div class="not-authenticated">
			<h2>Please log in to view subscription options</h2>
			<a href="/login" class="btn btn-primary">Login</a>
		</div>
	)}
</AccountPageLayout>