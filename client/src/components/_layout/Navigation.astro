---
import { getSession } from '../../lib/auth-utils';

// Get user session from Express auth server
const session = await getSession(Astro.request);

const user = session?.user;
const isAuthenticated = !!user;

const MENU = [
  {
    title: "Booking",
    url: "/booking",
  },
];

if (isAuthenticated) {
  MENU.push({
    title: "Account",
    url: "/account",
  });
} else {
  MENU.push({
    title: "Login",
    url: "/login",
  });
  MENU.push({
    title: "Register",
    url: "/register",
  });
}
---

<script>
  // Global variables for scroll behavior
  let lastScrollTop = 0;
  let lastScrollTopBeforeHide = 0;
  const headerHidePosition = 900;
  const gapBeforeHide = 300;
  let scrollHandler: any = null;

  // Initialize navigation functionality
  function initializeNavigation() {
    const header = document.querySelector(".header");
    const menuButton = document.querySelector(".header__menu__button");
    const menu = document.querySelector(".header__menu");
    const links = document.querySelectorAll(".header__menu__link");

    // Menu button functionality
    if (menuButton) {
      // Remove existing listener if any
      menuButton.replaceWith(menuButton.cloneNode(true));
      const newMenuButton = document.querySelector(".header__menu__button");
      
      newMenuButton?.addEventListener("click", () => {
        console.log("Menu button clicked");
        const currentMenu = document.querySelector(".header__menu");
        if (currentMenu?.classList.contains("is-opened")) {
          newMenuButton.ariaLabel = "Ouvrir le menu";
          currentMenu.classList.remove("is-opened");
        } else if (currentMenu) {
          newMenuButton.ariaLabel = "Fermer le menu";
          currentMenu.classList.add("is-opened");
        }
      });
    }

    // Menu links functionality
    if (links) {
      links.forEach((linkItem) => {
        // Remove existing listener by cloning
        const newLink = linkItem.cloneNode(true);
        linkItem.parentNode?.replaceChild(newLink, linkItem);
        
        newLink.addEventListener("click", () => {
          const currentMenu = document.querySelector(".header__menu");
          if (currentMenu?.classList.contains("is-opened")) {
            currentMenu.classList.remove("is-opened");
          }
        });
      });
    }

    // Logout button functionality
    const logoutButton = document.querySelector(".logout-button");
    if (logoutButton) {
      // Remove existing listener by cloning
      const newLogoutButton = logoutButton.cloneNode(true);
      logoutButton.parentNode?.replaceChild(newLogoutButton, logoutButton);
      
      newLogoutButton.addEventListener("click", async () => {
        const { signOut } = await import("../../lib/auth-client");
        await signOut();
        window.location.href = "/login";
      });
    }

    // Remove previous scroll handler if exists
    if (scrollHandler) {
      document.removeEventListener("scroll", scrollHandler);
    }

    // Scroll behavior functionality
    scrollHandler = () => {
      const st = window.pageYOffset || document.documentElement.scrollTop;
      const scrollDirection = st > lastScrollTop ? "down" : "up";
      const gapIsGreat = st > lastScrollTopBeforeHide + gapBeforeHide;

      lastScrollTop = st <= 0 ? 0 : st;

      if (scrollDirection === "up") {
        lastScrollTopBeforeHide = st;
      }
      
      const currentHeader = document.querySelector(".header");
      const currentMenu = document.querySelector(".header__menu");
      
      if (currentHeader) {
        if (
          scrollDirection === "down" &&
          window.scrollY > headerHidePosition &&
          gapIsGreat &&
          !currentMenu?.classList.contains("is-opened")
        ) {
          currentHeader.classList.add("is-hidden");
        } else if (currentHeader.classList.contains("is-hidden")) {
          currentHeader.classList.remove("is-hidden");
          lastScrollTopBeforeHide = st;
        }
      }
    };

    document.addEventListener("scroll", scrollHandler);

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      // Remove existing listener by cloning
      const newAnchor = anchor.cloneNode(true);
      anchor.parentNode?.replaceChild(newAnchor, anchor);
      
      newAnchor.addEventListener("click", (e) => {
        e.preventDefault();

        if (e.currentTarget) {
          const id = (e.currentTarget as HTMLAnchorElement).getAttribute("href");

          if (id) {
            const divToScrollTo = document.querySelector(id);

            if (divToScrollTo) {
              divToScrollTo.scrollIntoView({
                behavior: "smooth",
              });
            }
          }
        }
      });
    });
  }

  // Initialize on page load (both initial load and SPA navigation)
  document.addEventListener("astro:page-load", initializeNavigation);
</script>
<ul class="header__menu">
  {
    MENU.map((menuItem) => (
      <li>
        <a class="header__menu__link" href={menuItem.url}>
          {menuItem.title}
        </a>
      </li>
    ))
  }
</ul>

<style>
  .header__menu {
    display: flex;
    align-items: center;
    justify-content: center;
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 64px;
    z-index: 80;
    transform: translateY(-100%);
    width: 100%;
    max-width: 300px;
    z-index: -1;
    right: 0;
    background-color: var(--c-white);
    transition: transform 300ms cubic-bezier(0.37, 0, 0.63, 1);

    &.is-opened {
      transform: translateY(0);
    }
    
    @media (--xsToSm) {
      width: 100%;
      max-width: none;
    }

    li {
      transition: background-color 300ms;
      border-bottom: 1px solid var(--c-light-grey);
      margin: 0;
      display: block;
      width: 100%;
      text-align: left;

      &:last-child {
        border-bottom: none;
      }
    }

    a, button {
      color: black;
      font-weight: 500;
      position: relative;
      transition: background-color 0.3s;
      padding: 10px 15px;
      width: 100%;
      color: var(--c-black);
      background-color: var(--c-white);
      display: block;
      font-size: 16px;
      text-align: left;

      &:focus-visible {
        outline: 1px solid;
        outline-offset: -1px;
      }

      &:hover {
        text-decoration: none;
        background-color: var(--c-light-grey);
      }
    }
  }
</style>