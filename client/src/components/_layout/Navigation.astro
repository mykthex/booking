---
import { getSession } from '../../lib/auth-utils';

// Get user session from Express auth server
const session = await getSession(Astro.request);

const user = session?.user;
const isAuthenticated = !!user;

const MENU = [
  {
    title: "Booking",
    url: "/booking",
  },
];

if (isAuthenticated) {
  MENU.push({
    title: "Account",
    url: "/account",
  });
} else {
  MENU.push({
    title: "Login",
    url: "/login",
  });
  MENU.push({
    title: "Register",
    url: "/register",
  });
}
---

<script>
  const header = document.querySelector(".header");
  const menuButton = document.querySelector(".header__menu__button");
  const menu = document.querySelector(".header__menu");
  const links = document.querySelectorAll(".header__menu__link");
  let lastScrollTop = 0;
  let lastScrollTopBeforeHide = 0;
  const headerHidePosition = 900;
  const gapBeforeHide = 300;

  if (menuButton) {
    menuButton.addEventListener("click", () => {
      if (menu?.classList.contains("is-opened")) {
        menuButton.ariaLabel = "Ouvrir le menu";
        menu.classList.remove("is-opened");
      } else if (menu) {
        menuButton.ariaLabel = "Fermer le menu";
        menu.classList.add("is-opened");
      }
    });
  }

  if (links) {
    links.forEach((linkItem) => {
      linkItem.addEventListener("click", () => {
        if (menu?.classList.contains("is-opened")) {
          menu.classList.remove("is-opened");
        }
      });
    });
  }

  document.querySelector(".logout-button")?.addEventListener("click", async () => {
    const { signOut } = await import("../../lib/auth-client");

    await signOut();

    window.location.href = "/login";
  });

  document.addEventListener("scroll", () => {
    const st = window.pageYOffset || document.documentElement.scrollTop;
    const scrollDirection = st > lastScrollTop ? "down" : "up";
    const gapIsGreat = st > lastScrollTopBeforeHide + gapBeforeHide;

    lastScrollTop = st <= 0 ? 0 : st;

    if (scrollDirection === "up") {
      lastScrollTopBeforeHide = st;
    }
    if (header) {
      if (
        scrollDirection === "down" &&
        window.scrollY > headerHidePosition &&
        gapIsGreat &&
        !menu?.classList.contains("is-opened")
      ) {
        header.classList.add("is-hidden");
      } else if (header.classList.contains("is-hidden")) {
        header.classList.remove("is-hidden");
        lastScrollTopBeforeHide = st;
      }
    }
  });

  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", (e) => {
      e.preventDefault();

      if (e.currentTarget) {
        const id = (e.currentTarget as HTMLAnchorElement).getAttribute("href");

        if (id) {
          const divToScrollTo = document.querySelector(id);

          if (divToScrollTo) {
            divToScrollTo.scrollIntoView({
              behavior: "smooth",
            });
          }
        }
      }
    });
  });
</script>
<ul class="header__menu">
  {
    MENU.map((menuItem) => (
      <li>
        <a class="header__menu__link" href={menuItem.url}>
          {menuItem.title}
        </a>
      </li>
    ))
  }
  {isAuthenticated && (
    <li>
      <button class="header__menu__link logout-button">
        Logout
      </button>
    </li>
  )}
</ul>

<style>
  .header__menu {
    padding: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 64px;
    padding: 12px;
    z-index: 80;
    transform: translateY(-100%);
    width: 100%;
    max-width: 300px;
    z-index: -1;
    right: 0;
    background-color: var(--c-white);
    transition: transform 500ms cubic-bezier(0.37, 0, 0.63, 1);

    &.is-opened {
      transform: translateY(0);
    }
    
    @media (--xsToSm) {
      width: 100%;
      max-width: none;
    }

    li {
      transition: background-color 300ms;
      border-bottom: 1px solid var(--c-black);
      margin: 0;
      display: block;
      width: 100%;
      text-align: left;

      &:last-child {
        border-bottom: none;
      }
    }

    a, button {
      color: black;
      font-weight: 500;
      position: relative;
      transition: background-color 0.3s;
      padding: 8px;
      width: 100%;
      color: var(--c-black);
      background-color: var(--c-white);
      display: block;
      font-size: 16px;
      text-align: left;

      &:focus-visible {
        outline: 1px solid;
        outline-offset: -1px;
      }

      &:hover {
        text-decoration: none;
        background-color: var(--c-light-grey);
      }
    }
  }
</style>