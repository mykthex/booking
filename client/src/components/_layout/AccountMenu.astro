---
import AdminMenu from './AdminMenu.astro';

const currentPath = Astro.url.pathname;
import { getSession } from '../../lib/auth-utils';

// Get user session from Express auth server
const session = await getSession(Astro.request);

const user = session?.user;
---
<div class="account-menu-wrapper">
  <button class="btn btn-neutral menu-trigger" id="menu-toggle">
    <div class="menu-trigger__content">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block h-5 w-5 stroke-current">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <span>Mon compte</span>
    </div>
  </button>
  <div class="account-menu" id="account-menu">
    <ul class="menu menu-lg bg-base-200">
      <li><a href="/account" class={currentPath === "/account" ? "menu-active" : ""}>Overview</a></li>
      <li><a href="/profile" class={currentPath === "/profile" ? "menu-active" : ""}>Profile</a></li>
      <li><a href="/subscribe" class={currentPath === "/subscribe" ? "menu-active" : ""}>Subscription</a></li>
      <li><a href="/booking">Book a court</a></li>
    </ul>
    {user?.role === "admin" && <AdminMenu />}
  </div>
</div>

<script>
  function initializeAccountMenu() {
    const menuToggle = document.getElementById('menu-toggle');
    const accountMenu = document.getElementById('account-menu');
    
    if (menuToggle && accountMenu) {
      const newMenuToggle = menuToggle.cloneNode(true);
      menuToggle.parentNode?.replaceChild(newMenuToggle, menuToggle);
      
      newMenuToggle.addEventListener('click', function() {
        const currentAccountMenu = document.getElementById('account-menu');
        if (currentAccountMenu) {
          currentAccountMenu.classList.toggle('menu-open');
        }
      });

      function handleOutsideClick(event: any) {
        const currentMenuToggle = document.getElementById('menu-toggle');
        const currentAccountMenu = document.getElementById('account-menu');
        
        if (currentMenuToggle && currentAccountMenu) {
          if (!currentMenuToggle.contains(event.target as Node) && !currentAccountMenu.contains(event.target as Node)) {
            currentAccountMenu.classList.remove('menu-open');
          }
        }
      }
      
      document.addEventListener('click', handleOutsideClick);
    }
  }

  // Initialize on page load (both initial load and SPA navigation)
  document.addEventListener('astro:page-load', initializeAccountMenu);
</script>

<style is:global>
  .account-menu {
    display: flex;
    flex-direction: column;

    .menu {
      width: 100%;

      @media (--md) {
        width: 300px;
      }
    }

    @media (--xsToSm) {
      max-height: 0;
      overflow: hidden;
      margin-top: 0;
      transition: max-height 0.3s ease-in-out, margin-top 0.3s ease-in-out;
      
      &.menu-open {
        max-height: 500px;
        margin-top: 20px;
      }
    }
  }

  .menu-trigger {
    display: none;
    width: 100%;
    gap: 15px;
    text-align: left;

    span {
      height: 100%;
    }

    @media (--xsToSm) {
      display: block;
    }
  }

  .menu-trigger__content {
    display: flex;
    align-items: center;
    gap: 5px;
  }
</style>