---
import SimpleColumn from '../components/SimpleColumn.astro';
import { ProfileUpdateForm } from '../components/profile-update/ProfileUpdateForm';

import { auth } from '../../../server/auth';
import AccountMenu from './AccountMenu.astro';

// Get user session from better-auth
const session = await auth.api.getSession({
  headers: Astro.request.headers
});

const user = session?.user;
const isAuthenticated = !!user;
---
<div class="main-container">
	<SimpleColumn>
		<div class="account-page">
			<AccountMenu />
			<div class="content-area">
				{isAuthenticated && user && (
					<div class="profile-section">
						<ProfileUpdateForm 
							currentUser={{
								name: user.name || "",
								surname: user.surname || "",
								id: user.id || ""
							}}
							client:load
						/>
					</div>
				)}
				
				{!isAuthenticated && (
					<div class="not-authenticated">
						<h2>Please log in to view your profile</h2>
						<a href="/login" class="btn btn-primary">Login</a>
					</div>
				)}
			</div>
		</div>
	</SimpleColumn>
</div>

<style>
	.container {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 40px 20px;
	}

	.account-page {
		display: flex;
		align-items: flex-start;
		gap: 40px;
		width: 100%;
		max-width: 1200px;
	}

	.not-authenticated {
		text-align: center;
		padding: 40px;
	}

	h1 {
		font-size: 2.5rem;
		text-align: left;
		margin-bottom: 20px;
		color: #333;
	}

	h2 {
		font-size: 1.8rem;
		margin-bottom: 20px;
		color: #666;
	}

	.menu {
		min-width: 200px;
		flex-shrink: 0;
	}
</style>
