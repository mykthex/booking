---
import BookingPage from '../components/BookingPage.astro';
import Layout from '../layouts/Layout.astro';
import { getSubscriptionStatus } from '../lib/subscription-utils';

// Get user session from Express auth server
let session = null;
let user = null;

try {
  const cookies = Astro.request.headers.get('cookie') || '';
  
  const response = await fetch('http://localhost:9000/api/auth/get-session', {
    method: 'GET',
    headers: {
      'Cookie': cookies,
      'Content-Type': 'application/json'
    }
  });
  
  if (response.ok) {
    session = await response.json();
    user = session?.user;
  }
} catch (error) {
  console.error('Error fetching session:', error);
}

const isAuthenticated = !!user;

// Redirect to login if user is not authenticated
if (!isAuthenticated) {
  return Astro.redirect('/login');
}

// Check subscription status
let subscriptionStatus = null;
let hasValidSubscription = false;

if (user?.email) {
  try {
    subscriptionStatus = await getSubscriptionStatus(user.email, isAuthenticated);
    hasValidSubscription = subscriptionStatus.isValid;
  } catch (error) {
    console.error('Error checking subscription:', error);
  }
}

// Redirect to subscribe page if no valid subscription
if (!hasValidSubscription) {
  return Astro.redirect('/subscribe?redirect=booking&message=subscription_required');
}
---

<Layout title="Book a court">
	<BookingPage user={user} session={session} />
</Layout>
