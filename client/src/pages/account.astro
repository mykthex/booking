---
import Layout from '../layouts/Layout.astro';
import AccountPage from '../components/AccountPage.astro';

// Get user session from Express auth server
let session = null;
let user = null;

try {
  const cookies = Astro.request.headers.get('cookie') || '';
  
  const response = await fetch('http://localhost:9000/api/auth/get-session', {
    method: 'GET',
    headers: {
      'Cookie': cookies,
      'Content-Type': 'application/json'
    }
  });
  
  if (response.ok) {
    session = await response.json();
    user = session?.user;
  }
} catch (error) {
  console.error('Error fetching session:', error);
}

const isAuthenticated = !!user;

// Redirect to 404 if user is not authenticated
if (!isAuthenticated) {
  return new Response(null, { status: 404 });
}
---

<Layout title="Account overview">
	<AccountPage user={user} session={session} />
</Layout>
