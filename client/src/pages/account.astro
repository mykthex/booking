---
import Layout from '../layouts/Layout.astro';
import AccountPage from '../components/AccountPage.astro';
import { getSession } from '../lib/auth-utils';

// Get user session from Express auth server
const session = await getSession(Astro.request);
const user = session?.user;
const isAuthenticated = !!user;

// Redirect to 404 if user is not authenticated
if (!isAuthenticated) {
  return new Response(null, { status: 404 });
}
---

<Layout title="Account overview">
	<AccountPage user={user} session={session} />
</Layout>
