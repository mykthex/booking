---
import Layout from '../layouts/Layout.astro';
import SubscribePage from '../components/Subscribe.astro';
import { getSession } from '../lib/auth-utils';

// Get user session from Express auth server
const session = await getSession(Astro.request);

const user = session?.user;
const isAuthenticated = !!user;

// Redirect to login if user is not authenticated
if (!isAuthenticated) {
  return Astro.redirect('/login');
}

// Get URL parameters for redirect handling
const redirectPage = Astro.url.searchParams.get('redirect');
const message = Astro.url.searchParams.get('message');
const showSubscriptionRequired = message === 'subscription_required';
---

<Layout title="Subscription">
	<SubscribePage showSubscriptionRequired={showSubscriptionRequired} />
</Layout>
