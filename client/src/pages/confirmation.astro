---
import Layout from '../layouts/Layout.astro';
import ConfirmationPage from '../components/ConfirmationPage.astro';
// Check if subscription was successful from query parameter
const subscriptionSuccess = Astro.url.searchParams.get('subscription') === 'success';
---

<Layout title="Confirmation">
	<ConfirmationPage subscriptionSuccess={subscriptionSuccess} />
</Layout>
